# Copy this file to .env and edit with your own secrets
# Do NOT commit your real API keys or database URLs!

# Google Gemini API key used by engine.py
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (Neon, Heroku, local, etc.)
# Example: postgres://user:pass@host:5432/dbname
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Optional: override the server port
#PORT=5000
